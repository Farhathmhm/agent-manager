# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9099
LOG_LEVEL=INFO

# KV Provider Configuration
KV_PROVIDER_TYPE=openbao
KV_PROVIDER_ADDRESS=http://localhost:8200
KV_PROVIDER_TOKEN=your-token-here
KV_PROVIDER_NAMESPACE=
KV_PROVIDER_MOUNT_PATH=secret

# TLS Configuration (optional)
KV_PROVIDER_TLS_CA_CERT=
KV_PROVIDER_TLS_CLIENT_CERT=
KV_PROVIDER_TLS_CLIENT_KEY=
KV_PROVIDER_TLS_INSECURE=false

# Authentication Configuration
AUTH_ENABLED=true
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URL=
